# GitHub API Configuration
# IMPORTANT: GitHub tokens are now managed via the Web UI or REST API
# You NO LONGER need to set tokens in this .env file
#
# To add GitHub tokens:
# 1. Start the server: npm start
# 2. Open http://localhost:3000
# 3. Go to "Tokens" tab
# 4. Click "Add Token" and enter:
#    - Token name (e.g., "My GitHub Token")
#    - GitHub token (ghp_xxxxx)
#    - Email (optional)
#    - Priority (optional, default 0)
# 5. Token is automatically verified and stored in MongoDB
#
# All tokens are automatically validated on server startup
# System will automatically switch to another token when one:
# - Hits rate limits (5000 requests/hour)
# - Expires or becomes invalid
# - Encounters authentication errors

# MongoDB Configuration
# Local: mongodb://localhost:27017/github-user-research
# Cloud: mongodb+srv://username:password@cluster.mongodb.net/github-user-research
MONGODB_URI=mongodb://localhost:27017/github-user-research

# Server Configuration
PORT=3000

# Search Configuration
ACCOUNT_TYPE=user
LOCATIONS=["Atlanta, GA","San Francisco, CA"]
START_YEAR=2011
END_YEAR=2025

# API Rate Limiting (in milliseconds)
RATE_LIMIT_DELAY=1000
MAX_RETRIES=3
